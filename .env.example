# act-flexi Environment Configuration
# Copy this file to .env and modify as needed

# ── Mode Selection ──────────────────────────────────────────────────────────
# Default mode: 'development' (uses overlayBridge mock for testing)
# Valid values: development | production | github
MODE=development

# ── WebSocket Server (development only) ─────────────────────────────────────
# Only used in development mode for editor ↔ overlay communication
# Leave blank in production/github mode (uses localStorage instead)
WS_URL=ws://localhost:5176

# ── GitHub Pages Sync ───────────────────────────────────────────────────────
# Enable localStorage sync for GitHub Pages deployment
GITHUB_SYNC_KEY=act-flexi-github-sync

# ── Editor URLs (for overlay link) ──────────────────────────────────────────
# Override for development (localhost)
EDITOR_URL=http://localhost:5174

# Override for GitHub Pages (set this to your actual URL when deploying)
# GITHUB_PAGES_URL=https://yourusername.github.io/act-flexi/
