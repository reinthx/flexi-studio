{
  "name": "act-flexi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:editor --host\" \"pnpm dev:overlay --host\"",
    "dev:editor": "pnpm --filter editor dev",
    "dev:overlay": "pnpm --filter overlay dev",
    "dev:ws": "node scripts/ws-server.js",
    "build": "node scripts/build-all.js",
    "build:github": "node scripts/build-github.js",
    "build:editor": "pnpm --filter editor build",
    "build:overlay": "pnpm --filter overlay build",
    "update-assets": "node scripts/update-assets.js",
    "preview": "cd dist/editor && npx http-server -p 3000",
    "preview:overlay": "cd dist/overlay && npx http-server -p 3001",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "2.1.9",
    "concurrently": "^9.2.1",
    "pako": "^2.1.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@10.33.0"
}
